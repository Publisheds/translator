{
  "name": "liwit-translator",
  "version": "2.0.0",
  "description": "Adobe Illustrator & InDesign translation panel — Liwit",
  "main": "./src/client-src/index.js",
  "scripts": {
    "start": "webpack-dev-server --port=9567 --config ./build-scripts/webpack.client.config.js --env target=web --mode development --open",
    "build:dev": "node ./build-scripts/build.js development",
    "build:prod": "node ./build-scripts/build.js production",
    "deploy:dev": "node ./build-scripts/deploy.js development",
    "deploy:prod": "node ./build-scripts/deploy.js production",
    "release:dev": "npm run build:dev && npm run deploy:dev",
    "release:prod": "npm run build:prod && npm run deploy:prod",
    "postinstall": "mkdirp src/session-src/node_modules"
  },
  "author": "Liwit",
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "@babel/preset-env": "^7.22.0",
    "@babel/preset-react": "^7.22.0",
    "autoprefixer": "^10.4.14",
    "babel-loader": "^9.1.2",
    "chalk": "^4.1.2",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.8.1",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^5.5.3",
    "javascript-obfuscator": "^4.0.0",
    "jsxbin": "^2.2.0",
    "mini-css-extract-plugin": "^2.7.6",
    "mkdirp": "^3.0.1",
    "postcss": "^8.4.24",
    "postcss-loader": "^7.3.3",
    "style-loader": "^3.3.3",
    "tailwindcss": "^3.3.2",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1",
    "webpack-node-externals": "^3.0.0",
    "zxp-sign-cmd": "^1.0.0"
  },
  "dependencies": {
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@reduxjs/toolkit": "^1.9.7",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "lucide-react": "^0.263.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^8.1.2",
    "regenerator-runtime": "^0.14.0",
    "tailwind-merge": "^1.14.0",
    "underscore": "^1.13.6"
  }
}
